    },
    {
      "name": "github",
      "marketplace": "claude-plugins-official",
      "command": "claude plugin install github@claude-plugins-official"
    },
    {
      "name": "code-simplifier",
      "marketplace": "claude-plugins-official",
      "command": "claude plugin install code-simplifier@claude-plugins-official"
    },
    {
      "name": "claude-code-setup",
      "marketplace": "claude-plugins-official",
      "command": "claude plugin install claude-code-setup@claude-plugins-official"
    },
    {
      "name": "gitlab",
      "marketplace": "claude-plugins-official",
      "command": "claude plugin install gitlab@claude-plugins-official"
    },
    {
      "name": "prompts.chat",
      "marketplace": "prompts.chat",
      "command": "claude plugin install prompts.chat@prompts.chat",
      "description": "Access thousands of AI prompts and skills directly in Claude Code"
    },
    {
      "name": "claude-mem",
      "marketplace": "thedotmack",
      "command": "claude plugin install claude-mem@thedotmack",
      "description": "Persistent memory compression system for Claude Code - persist context across sessions"
    }
  ],
  "marketplaces": [
    {
      "name": "claude-plugins-official",
      "source": "https://plugins.anthropic.com/official"
    },
    {
      "name": "prompts.chat",
      "source": "https://github.com/f/prompts.chat",
      "type": "github",
      "description": "Official prompts.chat marketplace - AI prompts, skills, and tools"
    },
    {
      "name": "thedotmack",
      "source": "https://github.com/thedotmack/claude-mem",
      "type": "github",
      "description": "Plugins by Alex Newman - Memory compression and context management"
    }
  ],
  "setup_commands": [
    "claude plugin marketplace add f/prompts.chat",
    "claude plugin install prompts.chat@prompts.chat",
    "claude plugin marketplace add thedotmack/claude-mem",
    "claude plugin install claude-mem@thedotmack"
  ],
  "notes": "Run plugin installations and marketplace setup when marketplaces are accessible"
}
